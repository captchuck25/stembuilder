# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# STEM Sketch — keep local only
/public/stem-sketch/
/app/tools/stem-sketch/*.htm
/app/tools/stem-sketch/*.HTM
/app/tools/stem-sketch/*.html
/app/tools/stem-sketch/*.md
/app/tools/stem-sketch/*.js
/app/tools/stem-sketch/*.tgz
